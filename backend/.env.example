PORT=4000

# CORS – restrict allowed origin in production (omit for wildcard *)
# CORS_ORIGIN=https://favagit.github.io

# Auth settings
AUTH_JWT_SECRET=replace_with_strong_secret
AUTH_JWT_EXPIRES_IN=12h
# Example:
# AUTH_USERS_JSON=[{"username":"admin","password":"change_me","role":"admin"},{"username":"viewer","password":"change_me","role":"viewer"}]
AUTH_USERS_JSON=

# Root folder shared with the service account in Google Drive
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Option 1: full JSON string as one env var
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","client_email":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"}

# Option 2: explicit credentials
# GOOGLE_CLIENT_EMAIL=
# GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# Domain-wide delegation (Google Workspace only):
# GOOGLE_IMPERSONATE_EMAIL=user@yourdomain.com

# OAuth2 user credentials (personal Gmail – required for uploads/writes):
# Run: npx tsx backend/scripts/get-oauth-token.ts <CLIENT_ID> <CLIENT_SECRET>
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REFRESH_TOKEN=
